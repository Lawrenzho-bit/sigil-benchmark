# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit .env. The app validates these on boot.
# ---------------------------------------------------------------------------

# Runtime: "development" relaxes security checks; "production" enforces them.
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-change-me-0000000000000000000000000000

# Public base URL of the app (used in emails, SAML ACS, Stripe redirects).
BASE_URL=http://localhost:8000

# --- Database --------------------------------------------------------------
# docker-compose provides this automatically; override for managed Postgres.
DATABASE_URL=postgresql+psycopg2://portal:portal@db:5432/portal

# --- Sessions / cookies ----------------------------------------------------
SESSION_COOKIE_NAME=acme_session
SESSION_LIFETIME_HOURS=72
# Set true in production (requires HTTPS).
COOKIE_SECURE=false

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# --- SMTP (email) ----------------------------------------------------------
# Leave SMTP_HOST blank in dev to print emails to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=Acme Portal <no-reply@acme.example>

# --- SAML SSO (optional; per-org config also stored in DB) -----------------
# Default IdP metadata URL used when an org has not configured its own.
SAML_DEFAULT_IDP_METADATA_URL=

# --- First-run seed (optional) --------------------------------------------
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_ORG_NAME=Acme Inc
