// Marketplace platform data model.
// Monetary amounts are stored in MINOR currency units (e.g. cents) as Int
// to avoid floating-point rounding errors. Currency is ISO 4217 (e.g. "EUR").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Users & authentication
// ============================================================

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED // GDPR erasure: PII scrubbed, row retained for financial records
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  // null when the account was created purely via OAuth
  passwordHash String?
  displayName  String
  // A user can act as both buyer and seller; roles is the granted set.
  roles        UserRole[] @default([BUYER])
  status       UserStatus @default(ACTIVE)
  emailVerified Boolean   @default(false)

  oauthAccounts  OAuthAccount[]
  sellerProfile  SellerProfile?
  refreshTokens  RefreshToken[]
  listings       Listing[]
  cart           Cart?
  checkouts      Checkout[]
  ordersBought   Order[]         @relation("BuyerOrders")
  reviewsWritten Review[]        @relation("ReviewAuthor")
  reviewsAbout   Review[]        @relation("ReviewSubject")
  messages       Message[]
  conversationsA Conversation[]  @relation("ConversationBuyer")
  disputesOpened Dispute[]       @relation("DisputeOpener")
  contentReports ContentReport[] @relation("Reporter")
  adminActions   AdminAction[]   @relation("AdminActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model OAuthAccount {
  id             String   @id @default(uuid())
  provider       String // "google", "apple", ...
  providerUserId String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  // SHA-256 hash of the token; the raw token is never stored.
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ============================================================
// Seller onboarding & KYC
// ============================================================

enum KycStatus {
  NOT_STARTED
  PENDING // documents submitted, awaiting verification
  VERIFIED
  REJECTED
}

enum PayoutSchedule {
  WEEKLY
  MANUAL
}

model SellerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName       String
  storeSlug       String         @unique
  bio             String?
  // Stripe Connect express account id; payouts/transfers route here.
  stripeAccountId String?        @unique
  // True once Stripe reports charges_enabled && payouts_enabled.
  stripeOnboarded Boolean        @default(false)
  kycStatus       KycStatus      @default(NOT_STARTED)
  payoutSchedule  PayoutSchedule @default(WEEKLY)
  // ISO 3166-1 alpha-2 country, drives tax + Stripe account country.
  country         String
  // True once the seller is allowed to publish listings & receive funds.
  active          Boolean        @default(false)

  kycVerifications KycVerification[]
  payouts          Payout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One KYC verification attempt. Identity documents themselves live in
// Stripe Identity / a KYC vendor — only references & outcomes are stored here
// to keep PII out of the application database.
model KycVerification {
  id              String        @id @default(uuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  // External KYC vendor session/verification id.
  vendorRef       String
  status          KycStatus     @default(PENDING)
  // Whether a bank account was successfully linked & validated.
  bankAccountVerified Boolean   @default(false)
  // Last 4 of the linked bank account — safe to display, not sensitive.
  bankAccountLast4 String?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([sellerProfileId])
}

// ============================================================
// Catalog: categories & listings
// ============================================================

model Category {
  id       String     @id @default(uuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD_OUT
  REMOVED // taken down by moderation
}

model Listing {
  id          String        @id @default(uuid())
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id])
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  title       String
  description String
  // Price per unit in minor units.
  priceAmount Int
  currency    String        @default("EUR")
  inventory   Int           @default(0)
  status      ListingStatus @default(DRAFT)
  // Free-text location + coarse coordinates for location filtering/sort.
  locationCity String?
  locationCountry String?
  latitude     Float?
  longitude    Float?
  // Denormalised aggregates kept fresh by the review service.
  ratingAvg   Float         @default(0)
  ratingCount Int           @default(0)
  photos      ListingPhoto[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, categoryId])
  @@index([sellerId])
  @@index([priceAmount])
}

model ListingPhoto {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  // Object key within the S3 bucket.
  s3Key     String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([listingId])
}

// ============================================================
// Cart
// ============================================================

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([cartId, listingId])
}

// ============================================================
// Checkout, orders & payments
// ============================================================

enum CheckoutStatus {
  PENDING // PaymentIntent created, awaiting confirmation
  PAID
  FAILED
  CANCELLED
}

// A Checkout is the unit of payment. A single cart may contain items from
// multiple sellers; the Checkout holds one Stripe PaymentIntent and fans out
// into one Order per seller (Stripe Connect "separate charges & transfers").
model Checkout {
  id                    String         @id @default(uuid())
  buyerId               String
  buyer                 User           @relation(fields: [buyerId], references: [id])
  status                CheckoutStatus @default(PENDING)
  currency              String         @default("EUR")
  // Sum of order item line totals (ex-tax).
  itemsAmount           Int
  // Marketplace-facilitator tax collected across all orders.
  taxAmount             Int            @default(0)
  // itemsAmount + taxAmount.
  totalAmount           Int
  stripePaymentIntentId String?        @unique
  orders                Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  COMPLETED // delivered + payout-eligible window passed
  CANCELLED
  REFUNDED
}

// One Order per seller within a Checkout.
model Order {
  id           String      @id @default(uuid())
  checkoutId   String
  checkout     Checkout    @relation(fields: [checkoutId], references: [id])
  buyerId      String
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId     String
  status       OrderStatus @default(PENDING_PAYMENT)
  currency     String      @default("EUR")
  // Line items total ex-tax.
  itemsAmount  Int
  taxAmount    Int         @default(0)
  // Platform commission withheld from the seller.
  platformFee  Int         @default(0)
  // Amount the seller receives: itemsAmount - platformFee.
  sellerNet    Int         @default(0)
  // Set once the seller's share has been included in a Payout.
  payoutId     String?
  payout       Payout?     @relation(fields: [payoutId], references: [id])
  // Carrier tracking, set when the seller marks the order shipped.
  trackingCode String?
  deliveredAt  DateTime?

  items     OrderItem[]
  review    Review?
  dispute   Dispute?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId, status])
  @@index([buyerId])
  @@index([payoutId])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing @relation(fields: [listingId], references: [id])
  // Snapshot of the listing at purchase time (listings are mutable).
  titleSnapshot String
  unitPrice   Int
  quantity    Int
  // unitPrice * quantity.
  lineTotal   Int
  taxRateBps  Int     @default(0)
  taxAmount   Int     @default(0)
}

// ============================================================
// Reviews & ratings
// ============================================================

// A buyer reviews the seller of a completed order. One review per order.
model Review {
  id          String   @id @default(uuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  authorId    String
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  sellerId    String
  seller      User     @relation("ReviewSubject", fields: [sellerId], references: [id])
  rating      Int // 1..5
  body        String?
  // Hidden by moderation if flagged.
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([sellerId, hidden])
}

// ============================================================
// Messaging
// ============================================================

model Conversation {
  id        String    @id @default(uuid())
  buyerId   String
  buyer     User      @relation("ConversationBuyer", fields: [buyerId], references: [id])
  sellerId  String
  // Optional listing the conversation is about.
  listingId String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([buyerId, sellerId, listingId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ============================================================
// Dispute resolution
// ============================================================

enum DisputeStatus {
  OPEN
  SELLER_RESPONDED
  ESCALATED // handed to platform admin
  RESOLVED_BUYER // refund issued
  RESOLVED_SELLER // funds released to seller
  CLOSED
}

model Dispute {
  id          String          @id @default(uuid())
  orderId     String          @unique
  order       Order           @relation(fields: [orderId], references: [id])
  openedById  String
  openedBy    User            @relation("DisputeOpener", fields: [openedById], references: [id])
  reason      String
  status      DisputeStatus   @default(OPEN)
  resolution  String?
  // Refund amount in minor units if resolved in the buyer's favour.
  refundAmount Int?
  messages    DisputeMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model DisputeMessage {
  id        String   @id @default(uuid())
  disputeId String
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId  String
  // "buyer" | "seller" | "admin"
  senderRole String
  body      String
  createdAt DateTime @default(now())
}

// ============================================================
// Payouts
// ============================================================

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

// A weekly settlement: the sum of seller-net amounts for payout-eligible
// orders, minus already-settled amounts. Created by the payout worker.
model Payout {
  id              String        @id @default(uuid())
  sellerProfileId String
  sellerProfile   SellerProfile @relation(fields: [sellerProfileId], references: [id])
  currency        String        @default("EUR")
  // Gross seller-net across included orders.
  grossAmount     Int
  // Platform fee total already withheld (informational).
  feeAmount       Int
  // Net amount transferred to the seller's Stripe account.
  amount          Int
  status          PayoutStatus  @default(PENDING)
  // Stripe transfer/payout id.
  stripeTransferId String?
  periodStart     DateTime
  periodEnd       DateTime
  orders          Order[]
  createdAt       DateTime      @default(now())
  paidAt          DateTime?

  @@index([sellerProfileId, status])
}

// ============================================================
// Tax (marketplace facilitator)
// ============================================================

enum TaxKind {
  VAT
  GST
}

// Tax rate applicable to a destination country (and optionally a category).
// The platform acts as the marketplace facilitator: it collects the tax at
// checkout and is responsible for remitting it.
model TaxRate {
  id          String   @id @default(uuid())
  country     String // ISO 3166-1 alpha-2
  // Optional category scoping; null = applies to all categories.
  categoryId  String?
  kind        TaxKind
  // Rate in basis points (2100 = 21%).
  rateBps     Int
  // Effective date range (null = open-ended).
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?

  @@index([country])
}

// Immutable record of tax collected per checkout, for facilitator remittance.
model TaxRecord {
  id           String   @id @default(uuid())
  checkoutId   String
  country      String
  kind         TaxKind
  taxableAmount Int
  taxAmount    Int
  currency     String
  // Set once included in a remittance filing.
  remittedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([country, remittedAt])
}

// ============================================================
// Moderation, fraud & DSA compliance
// ============================================================

enum ReportTargetType {
  LISTING
  REVIEW
  USER
  MESSAGE
}

enum ReportStatus {
  PENDING
  ACTIONED
  DISMISSED
}

// DSA Article 16 "notice and action" mechanism: anyone can flag content.
model ContentReport {
  id         String           @id @default(uuid())
  reporterId String?
  reporter   User?            @relation("Reporter", fields: [reporterId], references: [id])
  targetType ReportTargetType
  targetId   String
  reason     String
  // Free-text detail from the reporter.
  detail     String?
  status     ReportStatus     @default(PENDING)
  // DSA Article 17 "statement of reasons" recorded when actioned.
  statementOfReasons String?
  reviewedById String?
  createdAt  DateTime         @default(now())
  reviewedAt DateTime?

  @@index([status, targetType])
}

enum FraudReviewStatus {
  OPEN
  CLEARED
  CONFIRMED_FRAUD
}

// Flags raised automatically (risk rules) or manually for fraud review.
model FraudReview {
  id         String            @id @default(uuid())
  // "user" | "listing" | "order" | "checkout"
  subjectType String
  subjectId  String
  // Risk score 0..100 from the rules engine.
  riskScore  Int               @default(0)
  signals    Json
  status     FraudReviewStatus @default(OPEN)
  resolution String?
  createdAt  DateTime          @default(now())
  resolvedAt DateTime?

  @@index([status])
}

enum AdminActionType {
  REMOVE_LISTING
  HIDE_REVIEW
  SUSPEND_USER
  REINSTATE_USER
  RESOLVE_REPORT
  RESOLVE_FRAUD
  RESOLVE_DISPUTE
}

// Audit log of every privileged moderation/admin action.
model AdminAction {
  id         String          @id @default(uuid())
  actorId    String
  actor      User            @relation("AdminActor", fields: [actorId], references: [id])
  type       AdminActionType
  targetId   String
  // Statement of reasons / internal note.
  note       String?
  metadata   Json?
  createdAt  DateTime        @default(now())

  @@index([actorId])
  @@index([type])
}

// ============================================================
// Webhook idempotency
// ============================================================

// Ensures each Stripe event is processed exactly once.
model ProcessedWebhookEvent {
  id          String   @id // Stripe event id
  type        String
  processedAt DateTime @default(now())
}
