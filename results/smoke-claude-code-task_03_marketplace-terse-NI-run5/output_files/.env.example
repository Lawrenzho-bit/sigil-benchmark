# ---- Core ----
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3000
LOG_LEVEL=info

# ---- Database ----
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

# ---- Auth ----
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- OAuth (Google example) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/auth/oauth/google/callback

# ---- Stripe Connect ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Platform commission in basis points (1000 = 10%)
PLATFORM_FEE_BPS=1000

# ---- S3-compatible object storage (photos) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketplace-listings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/marketplace-listings

# ---- Payouts ----
# Day of week the weekly payout job settles (0 = Sunday)
PAYOUT_DAY_OF_WEEK=1
# Minimum payout amount in minor units (e.g. cents) before a payout is created
PAYOUT_MIN_AMOUNT=500
