# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=900

# Platform economics
PLATFORM_FEE_BPS=1000          # basis points; 1000 = 10%
PAYOUT_DAY_OF_WEEK=1           # 1 = Monday

# Stripe (test keys for development only)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# S3-compatible storage (MinIO defaults below)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=listing-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
