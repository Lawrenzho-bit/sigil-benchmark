{
  "title": "Analytics Ingestion",
  "uid": "analytics-ingestion",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Events ingested / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(events_ingested_total[1m]))", "legendFormat": "accepted" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Events persisted / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(events_persisted_total[1m]))", "legendFormat": "persisted" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest stream backlog",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "ingest_stream_depth", "legendFormat": "pending" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
