# Copy to .env and adjust for your environment.

# --- Datastores ---
DATABASE_URL=postgresql://analytics:analytics@localhost:5432/analytics
REDIS_URL=redis://localhost:6379/0

# --- App ---
ENVIRONMENT=development
# Generate a strong value for production, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
SECRET_KEY=dev-insecure-change-me

# --- Ingestion ---
MAX_EVENTS_PER_REQUEST=500
INGEST_BATCH_SIZE=500
INGEST_RATE_LIMIT_PER_MIN=120000

# --- Streaming / caching ---
STREAM_INTERVAL_SECONDS=2.0
QUERY_CACHE_TTL_SECONDS=10
SESSION_TTL_SECONDS=28800

# --- Demo bootstrap (disable in production) ---
BOOTSTRAP_DEMO=true
DEMO_TENANT=demo
DEMO_USER_EMAIL=admin@demo.test
DEMO_USER_PASSWORD=demo12345
DEMO_API_TOKEN=tok_demo_local_dev_token
