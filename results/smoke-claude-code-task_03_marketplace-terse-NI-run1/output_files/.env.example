# --- Core ---
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

# --- Redis (sessions, rate limit, cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# --- OAuth (Google) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback

# --- Stripe Connect ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_PLATFORM_FEE_BPS=1000           # 10.00%
STRIPE_TAX_ENABLED=true

# --- S3 / Object storage (also works with MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketplace-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/marketplace-uploads

# --- Email (transactional) ---
EMAIL_FROM=no-reply@marketplace.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Admin bootstrap ---
ADMIN_BOOTSTRAP_EMAIL=admin@marketplace.local
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login
