# --- HTTP ---
PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by the customer web portal / agent SPA
CORS_ORIGINS=http://localhost:5173

# --- Auth ---
# 32+ random bytes. Rotate via JWT_SECRET_PREVIOUS for zero-downtime rotation.
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=3600

# --- Database ---
DATABASE_URL=postgres://support:support@localhost:5432/support
PG_POOL_MAX=20

# --- Email (outbound SMTP relay; SPF/DKIM/DMARC handled at the relay) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Address tickets are sent from; inbound parsing keys replies off the +token suffix
SUPPORT_FROM_ADDRESS=support@example.com
SUPPORT_DOMAIN=example.com

# --- Inbound webhook (mail provider posts parsed messages here) ---
INBOUND_WEBHOOK_SECRET=change-me-inbound-secret

# --- Compliance ---
# Days before resolved tickets + PII are purged. 0 disables automated purge.
GDPR_RETENTION_DAYS=730
# Public base URL used in CSAT survey + portal links
PUBLIC_BASE_URL=http://localhost:3000

# --- Optional Slack channel ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
