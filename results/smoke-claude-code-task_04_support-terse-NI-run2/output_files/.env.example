DATABASE_URL=postgres://support:support@localhost:5432/support_desk
PORT=3000

# Session
SESSION_SECRET=change-me-in-prod

# Inbound IMAP (production: use Postmark/SES inbound webhook instead)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Outbound SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=support@example.com
SMTP_PASS=
SMTP_FROM="Support <support@example.com>"

# Slack
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# SLA defaults (minutes)
SLA_FIRST_RESPONSE_MIN=60
SLA_RESOLUTION_MIN=1440

# GDPR
RETENTION_DAYS=1095
