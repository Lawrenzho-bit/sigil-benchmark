# Copy to .env and adjust for your environment.

# --- Storage ---
DATABASE_URL=postgresql://analytics:analytics@localhost:5432/analytics
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate a strong value in production, e.g. `openssl rand -hex 32`
SESSION_SECRET=dev-secret-change-me
SESSION_TTL_SECONDS=86400

# --- Behaviour ---
CACHE_TTL_SECONDS=10
INGEST_RATE_LIMIT=2000          # ingestion requests/sec per tenant
DASHBOARD_RATE_LIMIT=120        # dashboard requests/min per user session
SEED_DEMO=true                  # create demo tenants/users on startup
CORS_ORIGINS=*
