# --- Core ---
NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# --- Database ---
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

# --- Auth ---
# 32+ byte secret used to sign session JWTs (HS256). Rotate via JWT_SECRET_PREVIOUS.
JWT_SECRET=change-me-to-a-long-random-string-min-32-bytes
JWT_SECRET_PREVIOUS=
ACCESS_TOKEN_TTL=900            # 15 min, seconds
REFRESH_TOKEN_TTL=2592000       # 30 days, seconds

# --- OAuth (Google example) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/oauth/google/callback

# --- Stripe Connect ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx
PLATFORM_FEE_BPS=1000           # 10.00% platform fee, in basis points

# --- S3-compatible object storage (photos) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketplace-photos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/marketplace-photos

# --- KYC provider (abstracted; see src/lib/kyc.ts) ---
KYC_PROVIDER=stripe_identity    # stripe_identity | mock

# --- Tax ---
TAX_PROVIDER=internal           # internal | stripe_tax
