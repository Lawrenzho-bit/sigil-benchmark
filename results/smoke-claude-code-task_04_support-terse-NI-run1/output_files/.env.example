APP_ENV=development
APP_SECRET=change-me-in-production
DATABASE_URL=postgresql+psycopg://helpdesk:helpdesk@db:5432/helpdesk
REDIS_URL=redis://redis:6379/0

# Outbound SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=helpdesk@example.com
SMTP_PASSWORD=
SMTP_FROM=support@example.com
SMTP_TLS=true

# Inbound mail webhook (e.g. SES, Mailgun, Postmark)
INBOUND_WEBHOOK_SECRET=change-me

# SLA defaults (minutes)
SLA_FIRST_RESPONSE_MIN=60
SLA_RESOLUTION_MIN=1440

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# GDPR / retention
RETENTION_DAYS_CLOSED_TICKETS=730
AUDIT_LOG_RETENTION_DAYS=2555

# Search
SEARCH_BACKEND=postgres_fts
