# Copy to .env and fill in. Never commit .env.

# Postgres (matches docker-compose service)
DATABASE_URL=postgresql://portal:portal@localhost:5432/portal?schema=public

# Public base URL, used in invite links
APP_URL=http://localhost:3000

# --- Deferred integrations: leave blank to run without them ---

# Stripe (src/lib/stripe.ts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# SAML SSO (src/lib/saml.ts)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_IDP_CERT=
