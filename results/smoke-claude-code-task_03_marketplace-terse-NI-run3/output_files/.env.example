# --- Core ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://marketplace:marketplace@localhost:5432/marketplace?schema=public

# --- Redis (cache + BullMQ job queues) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# --- Stripe Connect (split payments) ---
# PCI DSS SAQ-A: card data never touches our servers. We only use Stripe.js /
# Checkout / hosted Connect onboarding. No raw PAN is accepted, processed or stored.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000          # platform commission in basis points (1000 = 10%)
PAYOUT_DAY_OF_WEEK=1           # 1 = Monday; weekly payout cron

# --- S3-compatible object storage (listing photos) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketplace-listings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/marketplace-listings

# --- KYC provider (identity + bank verification) ---
# Onboarding KYC is delegated to Stripe Connect's hosted flow by default.
# Set a dedicated provider here only if running KYC outside Stripe.
KYC_PROVIDER=stripe

# --- Tax (marketplace facilitator VAT/GST) ---
# Stripe Tax is used to calculate marketplace-facilitator tax at checkout.
STRIPE_TAX_ENABLED=true
PLATFORM_TAX_COUNTRY=IE        # platform's country of establishment
