# --- Core ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---
# Used by the app, worker, and migration scripts.
DATABASE_URL=postgres://support:support@localhost:5432/support

# --- Auth ---
# CHANGE THESE IN PRODUCTION. Use long random strings.
JWT_SECRET=dev-only-change-me-agent-secret
JWT_CUSTOMER_SECRET=dev-only-change-me-customer-secret
JWT_EXPIRES_IN=12h

# --- Outbound email (SMTP) ---
# If SMTP_HOST is empty, the mailer falls back to a console transport
# that logs messages instead of sending them (useful for local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM="Support <support@example.com>"

# Domain used to generate ticket reply addresses, e.g. support+T1234@example.com
SUPPORT_INBOUND_DOMAIN=example.com
SUPPORT_INBOUND_LOCALPART=support

# --- Inbound email webhook ---
# Shared secret expected from the inbound mail provider (SendGrid/Mailgun/SES).
INBOUND_WEBHOOK_SECRET=dev-only-change-me-inbound-secret

# --- SLA worker ---
SLA_SCAN_INTERVAL_MS=60000

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# --- GDPR / retention ---
# Days after which closed tickets become eligible for anonymization.
# 0 disables automatic retention enforcement.
RETENTION_CLOSED_TICKET_DAYS=0
