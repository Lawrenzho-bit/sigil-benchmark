{
  "name": "support-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Customer support ticketing tool — email + web portal + agent inbox, SLA, KB, CSAT, reporting",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "ts-node --transpile-only src/scripts/migrate.ts",
    "seed": "ts-node --transpile-only src/scripts/seed.ts",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
