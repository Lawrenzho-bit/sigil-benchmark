# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit the real .env. All values are read by
# app/config.py via pydantic-settings. Missing required values fail fast.
# ---------------------------------------------------------------------------

# Core -----------------------------------------------------------------------
ENVIRONMENT=development                 # development | staging | production
DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
BASE_URL=http://localhost:8000

# Database -------------------------------------------------------------------
# Use the async driver. docker-compose provides this value automatically.
DATABASE_URL=postgresql+asyncpg://portal:portal@db:5432/portal

# Sessions -------------------------------------------------------------------
SESSION_COOKIE_NAME=portal_session
SESSION_LIFETIME_HOURS=72
# true in production so cookies are only sent over HTTPS.
SESSION_COOKIE_SECURE=false

# Login rate limiting --------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5                    # failures before lockout
LOGIN_ATTEMPT_WINDOW_MINUTES=15         # rolling window for counting failures
LOGIN_LOCKOUT_MINUTES=15                # how long a locked identity stays out

# Stripe ---------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Email (SMTP) ---------------------------------------------------------------
# EMAIL_BACKEND=console logs emails instead of sending (good for local dev).
EMAIL_BACKEND=console                   # console | smtp
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Sigil Portal
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# SAML SSO (optional; per-org IdP config is stored in the database) ----------
SAML_SP_ENTITY_ID=http://localhost:8000/saml/metadata
