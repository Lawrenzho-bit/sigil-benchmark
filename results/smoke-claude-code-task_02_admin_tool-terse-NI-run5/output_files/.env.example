# ---------------------------------------------------------------------------
# Internal Admin Tool — environment configuration
# Copy to .env and fill in. Never commit a populated .env.
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
PORT=3000
# Public base URL of this app; used to build SSO callback URLs.
APP_BASE_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://admin:admin@localhost:5432/admin_tool?schema=public

# --- Session ---
# 64+ random chars. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
# Session idle lifetime in minutes.
SESSION_TTL_MINUTES=480

# --- Authorization bootstrap ---
# Comma-separated SSO emails granted SUPER_ADMIN on first login (JIT provisioning).
# Everyone else is provisioned as READ_ONLY and must be elevated by a Super Admin.
SUPER_ADMIN_EMAILS=you@example.com

# --- SAML 2.0 (set SAML_ENABLED=true to activate) ---
SAML_ENABLED=false
SAML_ENTRY_POINT=https://idp.example.com/sso/saml
SAML_ISSUER=internal-admin-tool
# IdP signing certificate (PEM body, no headers, single line).
SAML_IDP_CERT=
# Optional SP private key + cert for signed requests (PEM, single line).
SAML_SP_PRIVATE_KEY=
SAML_SP_CERT=

# --- OIDC (set OIDC_ENABLED=true to activate) ---
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://idp.example.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid profile email

# --- Dev-only mock login ---
# When true AND NODE_ENV!=production, exposes POST /auth/dev/login for local
# development without a real IdP. MUST be false in any shared environment.
AUTH_DEV_MODE=true

# --- Logging ---
LOG_LEVEL=info
