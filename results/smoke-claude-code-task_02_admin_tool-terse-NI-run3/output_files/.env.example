# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Public base URL of this admin tool (used to build SSO callback URLs).
APP_BASE_URL=http://localhost:4000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:admin@localhost:5432/admintool?schema=public

# ─── Sessions ────────────────────────────────────────────────────────────────
# 64+ random chars. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-48-bytes
# Session idle lifetime in minutes.
SESSION_TTL_MINUTES=480

# ─── Access control ──────────────────────────────────────────────────────────
# Comma-separated emails granted SUPER_ADMIN on first SSO login. Bootstrap only.
BOOTSTRAP_SUPER_ADMINS=you@example.com
# If true, unknown SSO users are auto-created as READ_ONLY. If false, only
# pre-provisioned users and bootstrap admins may sign in.
ALLOW_JIT_PROVISIONING=true

# ─── Impersonation ───────────────────────────────────────────────────────────
# Secret shared with the main SaaS app to verify impersonation tokens.
IMPERSONATION_JWT_SECRET=change-me-impersonation-secret
IMPERSONATION_TOKEN_TTL_MINUTES=15

# ─── SAML 2.0 (leave blank to disable this provider) ─────────────────────────
SAML_ENTRY_POINT=
SAML_ISSUER=saas-admin-tool
SAML_IDP_CERT=
# SP private key + cert for signing AuthnRequests (optional but recommended).
SAML_SP_PRIVATE_KEY=
SAML_SP_CERT=

# ─── OIDC (leave blank to disable this provider) ─────────────────────────────
OIDC_ISSUER=
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
