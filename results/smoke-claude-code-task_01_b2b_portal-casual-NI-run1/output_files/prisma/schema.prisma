// Prisma schema for the SaaS portal.
//
// Multi-tenant model: top-level Organization owns Users-via-Membership.
// All tenant-scoped data carries an organizationId for row-level access checks
// (enforced in app code via lib/rbac.ts and audited via lib/audit.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  VIEWER
}

enum BillingPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AuditCategory {
  AUTH
  MEMBER
  BILLING
  SETTINGS
  DATA
  SECURITY
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Billing
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?  @unique
  plan                  BillingPlan        @default(STARTER)
  subscriptionStatus    SubscriptionStatus @default(TRIALING)
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?

  memberships  Membership[]
  invitations  Invitation[]
  ssoConnection SsoConnection?
  auditEvents  AuditEvent[]
  apiKeys      ApiKey[]

  @@index([stripeCustomerId])
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  // Argon2id hash. Null when the user only authenticates via SSO/OAuth.
  passwordHash     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastLoginAt      DateTime?
  // GDPR: marks the user has requested deletion; processed by background job
  // within the legally-required window. Sessions are revoked immediately on request.
  deletionRequestedAt DateTime?

  memberships Membership[]
  sessions    Session[]
  accounts    Account[]
  auditEvents AuditEvent[]
}

model Membership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role     @default(VIEWER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           Role         @default(VIEWER)
  // SHA-256 of the random token sent in the email. Raw token is never persisted.
  tokenHash      String       @unique
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  invitedById    String
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
}

// NextAuth-compatible Account/Session tables (kept here so we have one source of truth).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SsoConnection {
  id             String   @id @default(cuid())
  organizationId String   @unique
  // Email domain that auto-routes to this connection (e.g. "acme.com").
  emailDomain    String   @unique
  // Display name for the IdP
  idpName        String
  ssoUrl         String
  entityId       String
  // AES-256-GCM ciphertext of PEM certificate. Decrypted only in-memory.
  certCiphertext String   @db.Text
  // Optionally enforce SSO-only (block password login for org users)
  enforced       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id             String         @id @default(cuid())
  organizationId String?
  actorUserId    String?
  category       AuditCategory
  action         String         // e.g. "member.invited", "billing.plan_changed"
  // Free-form JSON payload, sanitized at write-time (no secrets/PII beyond user id+email).
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime       @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([category, createdAt])
}

model ApiKey {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  // SHA-256 of the raw key. Raw key is returned ONCE at creation, never stored.
  keyHash        String   @unique
  // Last 4 chars shown in UI for identification.
  last4          String
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}
