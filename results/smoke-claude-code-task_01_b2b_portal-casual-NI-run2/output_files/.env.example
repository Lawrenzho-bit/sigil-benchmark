# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
# Set ENVIRONMENT to "production" before deploying. In production the app
# refuses to boot with insecure defaults (see app/config.py).
ENVIRONMENT=development
DEBUG=true

# 32+ random bytes. Generate with: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-secret-change-me-0000000000000000

# Public base URL of the portal. Used for invite links, OAuth/SAML callbacks,
# Stripe redirect URLs and email links. No trailing slash.
BASE_URL=http://localhost:8000

# Comma-separated hostnames allowed in the Host header.
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Postgres in production. SQLite is supported for local dev / tests only.
DATABASE_URL=postgresql+psycopg://saas:saas@localhost:5432/saas_portal

# ----------------------------------------------------------------------------
# Redis (rate limiting + session store). Optional — falls back to in-process.
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# Email (SMTP). With EMAIL_BACKEND=console messages are printed, not sent.
# ----------------------------------------------------------------------------
EMAIL_BACKEND=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=SaaS Portal <no-reply@example.com>

# ----------------------------------------------------------------------------
# Stripe billing
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring price IDs created in your Stripe dashboard, one per plan.
STRIPE_PRICE_STARTER=price_starter_xxx
STRIPE_PRICE_PRO=price_pro_xxx
STRIPE_PRICE_ENTERPRISE=price_enterprise_xxx

# ----------------------------------------------------------------------------
# SAML SSO (per-org config is stored in the DB; these are SP-wide defaults)
# ----------------------------------------------------------------------------
SAML_SP_ENTITY_ID=http://localhost:8000/auth/sso/metadata

# ----------------------------------------------------------------------------
# Security tuning
# ----------------------------------------------------------------------------
SESSION_LIFETIME_HOURS=720
LOGIN_RATE_LIMIT=5/5m
SIGNUP_RATE_LIMIT=10/1h
