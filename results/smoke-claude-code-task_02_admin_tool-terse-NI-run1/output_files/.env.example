# Application
ENV=dev
SESSION_SECRET=change-me-to-long-random-string
DATABASE_URL=postgresql+psycopg://admin:admin@localhost:5432/admin_tool
REDIS_URL=redis://localhost:6379/0

# OIDC (e.g. Okta, Google Workspace, Auth0)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc/callback

# SAML 2.0
SAML_METADATA_URL=https://idp.example.com/metadata
SAML_SP_ENTITY_ID=admin-tool
SAML_SP_ACS_URL=http://localhost:8000/auth/saml/acs

# Role mapping: comma-separated IDP groups -> internal role
ROLE_MAP_SUPER_ADMIN=admin-super
ROLE_MAP_ACCOUNT_ADMIN=admin-account
ROLE_MAP_SUPPORT=admin-support
ROLE_MAP_FINANCE=admin-finance
ROLE_MAP_READ_ONLY=admin-readonly

# Impersonation token TTL (seconds)
IMPERSONATION_TTL=900
