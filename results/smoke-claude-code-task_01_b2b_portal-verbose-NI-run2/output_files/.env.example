# ---------------------------------------------------------------------------
# B2B SaaS Portal — environment template
# Copy to `.env` for local dev. In production, inject these via your platform's
# secret manager. NEVER commit a populated .env file.
# ---------------------------------------------------------------------------

# Core
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# Database — Postgres connection string.
# The pooled URL is used by the app; DIRECT_URL is used by Prisma migrations.
DATABASE_URL=postgresql://portal:portal@localhost:5432/portal?schema=public&connection_limit=10
DIRECT_URL=postgresql://portal:portal@localhost:5432/portal?schema=public

# Session — 32+ byte random secret. Generate: `openssl rand -base64 48`
SESSION_SECRET=replace-me-with-a-long-random-string-min-32-bytes
SESSION_IDLE_TIMEOUT_MINUTES=60
SESSION_ABSOLUTE_TIMEOUT_HOURS=168

# Field encryption — 32-byte key, base64 encoded. Generate: `openssl rand -base64 32`
# Used to encrypt sensitive columns at rest (TOTP secrets, SAML private keys).
FIELD_ENCRYPTION_KEY=replace-me-base64-32-bytes

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Email (Resend). Swap the provider in src/lib/email.ts if you use SES/Postmark.
RESEND_API_KEY=re_xxx
EMAIL_FROM="Portal <noreply@example.com>"

# Observability
LOG_LEVEL=info
METRICS_TOKEN=replace-me-bearer-token-for-/api/metrics
