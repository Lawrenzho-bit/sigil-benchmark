# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values before running.
# ---------------------------------------------------------------------------

# Postgres connection string.
DATABASE_URL="postgresql://portal:portal@localhost:5432/portal?schema=public"

# Public base URL of the app (no trailing slash). Used for SAML + Stripe redirects.
APP_URL="http://localhost:3000"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# Price IDs for each plan (create them in the Stripe dashboard).
STRIPE_PRICE_STARTER="price_xxx"
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_ENTERPRISE="price_xxx"

# --- Email (SMTP) -----------------------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
EMAIL_FROM="B2B Portal <no-reply@example.com>"

# --- SAML SSO (optional; leave blank to disable the SSO button) -------------
# Identity Provider single sign-on URL.
SAML_IDP_SSO_URL=""
# IdP signing certificate (PEM, single line with \n or base64 — see lib/saml.ts).
SAML_IDP_CERT=""
# Service Provider entity ID (this app). Defaults to APP_URL if blank.
SAML_SP_ENTITY_ID=""
