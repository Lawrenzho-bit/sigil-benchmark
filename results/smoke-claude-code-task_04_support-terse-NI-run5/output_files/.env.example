# --- Core ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgres://support:support@localhost:5432/support_desk

# --- Auth ---
# Use a long random string in production. Rotate via JWT_SECRET_PREVIOUS for zero-downtime rotation.
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_SECONDS=3600
PORTAL_JWT_TTL_SECONDS=86400

# --- Email ---
# Outbound SMTP relay (must have SPF/DKIM/DMARC configured for EMAIL_DOMAIN at DNS level).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_DOMAIN=support.example.com
EMAIL_FROM_NAME=Acme Support
# Inbound replies are routed to support+<ticketRef>@EMAIL_DOMAIN for reliable threading.
INBOUND_ADDRESS_LOCALPART=support

# Shared secret for the inbound email webhook (SES/Mailgun/Postmark style).
INBOUND_WEBHOOK_SECRET=change-me-inbound-secret

# --- Workers ---
SLA_POLL_INTERVAL_MS=60000
EMAIL_POLL_INTERVAL_MS=15000

# --- Compliance (GDPR) ---
# Days after which closed tickets are anonymised. 0 disables automated retention.
RETENTION_CLOSED_TICKET_DAYS=730
RETENTION_AUDIT_LOG_DAYS=2555
