# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
# Postgres connection string.
DATABASE_URL="postgresql://portal:portal@localhost:5432/portal?schema=public"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of the deployed app (no trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
# Set to true behind a reverse proxy / load balancer that terminates TLS.
AUTH_TRUST_HOST="true"

# ---------------------------------------------------------------------------
# Stripe billing (optional — billing UI degrades gracefully if unset)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs for each plan (create them in the Stripe dashboard).
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# ---------------------------------------------------------------------------
# Email (optional — falls back to console logging if SMTP unset)
# ---------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="B2B Portal <no-reply@example.com>"

# ---------------------------------------------------------------------------
# SAML SSO (optional — email/password works without this)
# ---------------------------------------------------------------------------
# IdP single sign-on URL.
SAML_ENTRY_POINT=""
# SP entity ID / issuer registered with the IdP.
SAML_ISSUER="b2b-saas-portal"
# IdP signing certificate (PEM, single line with \n or full multi-line value).
SAML_IDP_CERT=""
